  "slices": [
    {
      "slice_name": "Order Metrics Over Time",
      "viz_type": "line",
      "datasource_name": "order_metrics",
      "params": {
        "datasource": "order_metrics",
        "viz_type": "line",
        "slice_id": null,
        "url_params": {},
        "granularity_sqla": "date",
        "time_grain_sqla": "P1D",
        "time_range": "Last 90 days",
        "metrics": [
          {
            "expressionType": "SIMPLE",
            "column": {
              "column_name": "total_orders",
              "type": "BIGINT"
            },
            "aggregate": "SUM",
            "label": "Total Orders"
          },
          {
            "expressionType": "SIMPLE",
            "column": {
              "column_name": "unique_customers",
              "type": "BIGINT"
            },
            "aggregate": "SUM",
            "label": "Unique Customers"
          },
          {
            "expressionType": "SIMPLE",
            "column": {
              "column_name": "avg_order_value",
              "type": "DOUBLE"
            },
            "aggregate": "AVG",
            "label": "Avg Order Value"
          }
        ],
        "adhoc_filters": [],
        "groupby": [],
        "limit": 25,
