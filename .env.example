# =============================================================================
# Medallion Pipeline — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values before running docker compose.
#
#   cp .env.example .env
#
# Lines starting with # are comments. Do NOT commit your .env file to git.
# =============================================================================


# -----------------------------------------------------------------------------
# MinIO Object Storage
# -----------------------------------------------------------------------------
# Username for the MinIO root (admin) account.
# Used by all services that write to or read from MinIO (dbt, Airflow, Iceberg).
MINIO_ROOT_USER=admin

# Password for the MinIO root account.
# Change this to a strong password before running in any shared environment.
MINIO_ROOT_PASSWORD=changeme123


# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# Superuser credentials for the shared PostgreSQL container.
# This instance hosts three databases: airflow, airbyte, and seed_db.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres


# -----------------------------------------------------------------------------
# Apache Airflow
# -----------------------------------------------------------------------------
# UID used when Airflow writes files (logs, DAGs) to mounted volumes.
# Set this to your local user ID to avoid permission issues on Linux/macOS:
#   export AIRFLOW_UID=$(id -u)
# On Windows with Docker Desktop, the default value of 50000 works fine.
AIRFLOW_UID=50000


# -----------------------------------------------------------------------------
# Apache Superset
# -----------------------------------------------------------------------------
# Secret key used to sign Superset session cookies and encrypt sensitive data.
# Generate a strong random value:
#   python -c "import secrets; print(secrets.token_hex(32))"
SUPERSET_SECRET_KEY=changeme_replace_with_random_secret_key


# -----------------------------------------------------------------------------
# Airbyte (optional)
# -----------------------------------------------------------------------------
# API key for authenticating with the Airbyte server API.
# Required only if you use the Airbyte API directly (e.g., from Airflow).
# Leave blank if you configure Airbyte connections manually via the UI.
AIRBYTE_API_KEY=
